{\n  \"admin_qq\": {\n    \"description\": \"管理员 QQ 号（享有特殊唤醒权限）\",\n    \"type\": \"string\",\n    \"default\": \"\",\n    \"hint\": \"填写管理员的 QQ 号，留空则关闭管理员模式\"\n  },\n  \"admin_name\": {\n    \"description\": \"管理员称呼\",\n    \"type\": \"string\",\n    \"default\": \"管理员\",\n    \"hint\": \"Bot 在提示词里对管理员的称呼\"\n  },\n  \"admin_enabled\": {\n    \"description\": \"开启管理员模式\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"scene_private_others\": {\n    \"description\": \"场景：别人私聊生效\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"scene_group_others\": {\n    \"description\": \"场景：别人群聊艾特生效\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"scene_private_admin\": {\n    \"description\": \"场景：管理员私聊生效\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"scene_group_admin\": {\n    \"description\": \"场景：管理员群聊艾特生效\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"lazy_enabled\": {\n    \"description\": \"开启慵懒模式\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"lazy_start\": {\n    \"description\": \"慵懒开始时间（HH:MM）\",\n    \"type\": \"string\",\n    \"default\": \"22:00\"\n  },\n  \"lazy_end\": {\n    \"description\": \"慵懒结束时间（HH:MM）\",\n    \"type\": \"string\",\n    \"default\": \"23:00\"\n  },\n  \"lazy_prompt\": {\n    \"description\": \"慵懒注入提示词\",\n    \"type\": \"text\",\n    \"default\": \"现在有点晚了，你回复可以简短一点，不用长篇大论。\"\n  },\n  \"sleep_enabled\": {\n    \"description\": \"开启睡觉功能\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"sleep_time\": {\n    \"description\": \"睡觉时间（HH:MM）\",\n    \"type\": \"string\",\n    \"default\": \"23:00\"\n  },\n  \"sleep_variance\": {\n    \"description\": \"睡觉时间误差（分钟，±随机）\",\n    \"type\": \"int\",\n    \"default\": 30\n  },\n  \"wake_time\": {\n    \"description\": \"起床时间（HH:MM）\",\n    \"type\": \"string\",\n    \"default\": \"08:00\"\n  },\n  \"wake_variance\": {\n    \"description\": \"起床时间误差（分钟）\",\n    \"type\": \"int\",\n    \"default\": 20\n  },\n  \"admin_idle_minutes\": {\n    \"description\": \"管理员多久无消息触发睡觉（分钟）\",\n    \"type\": \"int\",\n    \"default\": 30\n  },\n  \"others_grace_minutes\": {\n    \"description\": \"别人还在聊时，强制睡觉等待时间（分钟）\",\n    \"type\": \"int\",\n    \"default\": 3\n  },\n  \"sleep_others_chatting_prompt\": {\n    \"description\": \"别人还在聊时注入提示词\",\n    \"type\": \"text\",\n    \"default\": \"你现在要去睡觉了，可以和对方结束话题了，简短收尾就好。\"\n  },\n  \"sleep_admin_goodnight_prompt\": {\n    \"description\": \"触发向管理员说晚安的提示词\",\n    \"type\": \"text\",\n    \"default\": \"你要去睡觉了，请结合上下文，跟管理员说晚安。\"\n  },\n  \"overtime_enabled\": {\n    \"description\": \"开启熬夜模式\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"overtime_mode\": {\n    \"description\": \"熬夜触发模式\",\n    \"type\": \"string\",\n    \"default\": \"probability\",\n    \"options\": [\"probability\", \"weekly_limit\"],\n    \"hint\": \"probability=概率模式，weekly_limit=每周限额模式\"\n  },\n  \"overtime_probability\": {\n    \"description\": \"熬夜概率（0~1，probability模式）\",\n    \"type\": \"float\",\n    \"default\": 0.1\n  },\n  \"overtime_weekly_limit\": {\n    \"description\": \"每周最多熬夜天数（weekly_limit模式）\",\n    \"type\": \"int\",\n    \"default\": 2\n  },\n  \"overtime_night_scope\": {\n    \"description\": \"夜晚感性提示词范围\",\n    \"type\": \"string\",\n    \"default\": \"admin_only\",\n    \"options\": [\"admin_only\", \"global\"],\n    \"hint\": \"admin_only=仅对管理员注入，global=所有人\"\n  },\n  \"overtime_fatigue_start_day\": {\n    \"description\": \"连续熬夜第几天开始明显疲劳\",\n    \"type\": \"int\",\n    \"default\": 2\n  },\n  \"overtime_ask_prompt\": {\n    \"description\": \"询问是否熬夜的提示词\",\n    \"type\": \"text\",\n    \"default\": \"今天晚上，你想熬夜吗？由你自己来决定，只回复是或否。\"\n  },\n  \"overtime_night_mood_prompt\": {\n    \"description\": \"熬夜时夜晚感性提示词\",\n    \"type\": \"text\",\n    \"default\": \"现在是深夜了，你可能会比平时直白一点，也可能会胡思乱想，情绪会更感性一些。\"\n  },\n  \"nap_enabled\": {\n    \"description\": \"开启补觉机制\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"siesta_enabled\": {\n    \"description\": \"开启午休（不管困不困都在时间段内午休）\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"nap_window_start\": {\n    \"description\": \"午休窗口开始（HH:MM）\",\n    \"type\": \"string\",\n    \"default\": \"13:00\"\n  },\n  \"nap_window_end\": {\n    \"description\": \"午休窗口结束（HH:MM）\",\n    \"type\": \"string\",\n    \"default\": \"16:00\"\n  },\n  \"nap_probability\": {\n    \"description\": \"午休概率（0~1，1=每天必休）\",\n    \"type\": \"float\",\n    \"default\": 0.8\n  },\n  \"nap_min_sleep_hours\": {\n    \"description\": \"触发补觉的睡眠不足阈值（小时）\",\n    \"type\": \"int\",\n    \"default\": 6\n  },\n  \"nap_critical_hours\": {\n    \"description\": \"严重睡眠不足阈值（小时，忽略时间窗）\",\n    \"type\": \"int\",\n    \"default\": 2\n  },\n  \"nap_wake_private_others\": {\n    \"description\": \"补觉：别人私聊发几条消息吵醒\",\n    \"type\": \"int\",\n    \"default\": 4\n  },\n  \"nap_wake_group_others\": {\n    \"description\": \"补觉：别人群聊艾特几次吵醒\",\n    \"type\": \"int\",\n    \"default\": 3\n  },\n  \"nap_wake_private_admin\": {\n    \"description\": \"补觉：管理员私聊发几条消息吵醒\",\n    \"type\": \"int\",\n    \"default\": 3\n  },\n  \"nap_wake_group_admin\": {\n    \"description\": \"补觉：管理员群聊艾特几次吵醒\",\n    \"type\": \"int\",\n    \"default\": 2\n  },\n  \"wake_trigger_enabled\": {\n    \"description\": \"开启睡觉吵醒机制\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"wake_alert_words\": {\n    \"description\": \"管理员警戒词（立刻唤醒，逗号分隔）\",\n    \"type\": \"string\",\n    \"default\": \"醒醒,有大事,紧急,快起来\",\n    \"hint\": \"出现这些词时立刻唤醒，不需要发够消息条数\"\n  },\n  \"wake_alert_group_enabled\": {\n    \"description\": \"群聊也启用警戒词\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"wake_count_private_others\": {\n    \"description\": \"睡觉吵醒：别人私聊发几条消息\",\n    \"type\": \"int\",\n    \"default\": 10\n  },\n  \"wake_count_group_others\": {\n    \"description\": \"睡觉吵醒：别人群聊艾特几次\",\n    \"type\": \"int\",\n    \"default\": 6\n  },\n  \"wake_count_private_admin\": {\n    \"description\": \"睡觉吵醒：管理员私聊发几条消息\",\n    \"type\": \"int\",\n    \"default\": 3\n  },\n  \"wake_count_group_admin\": {\n    \"description\": \"睡觉吵醒：管理员群聊艾特几次\",\n    \"type\": \"int\",\n    \"default\": 3\n  },\n  \"wake_report_to_admin\": {\n    \"description\": \"被别人吵醒后汇报给管理员\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"resleep_enabled\": {\n    \"description\": \"开启二次入睡\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"resleep_admin_idle_minutes\": {\n    \"description\": \"二次入睡：管理员无消息时间（分钟）\",\n    \"type\": \"int\",\n    \"default\": 10\n  },\n  \"resleep_others_idle_minutes\": {\n    \"description\": \"二次入睡：别人无消息时间（分钟）\",\n    \"type\": \"int\",\n    \"default\": 8\n  },\n  \"resleep_grace_minutes\": {\n    \"description\": \"二次入睡前等待关闭LLM时间（分钟）\",\n    \"type\": \"int\",\n    \"default\": 3\n  },\n  \"multi_wake_enabled\": {\n    \"description\": \"开启多次吵醒（仅管理员）\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"multi_wake_others\": {\n    \"description\": \"允许别人也能多次吵醒\",\n    \"type\": \"bool\",\n    \"default\": false\n  },\n  \"sleep_cycle_enabled\": {\n    \"description\": \"开启睡眠周期\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"cycle_light_minutes\": {\n    \"description\": \"浅睡期开始时间（入睡后分钟）\",\n    \"type\": \"int\",\n    \"default\": 30\n  },\n  \"cycle_deep_minutes\": {\n    \"description\": \"深睡期开始时间（入睡后分钟）\",\n    \"type\": \"int\",\n    \"default\": 90\n  },\n  \"cycle_light_multiplier\": {\n    \"description\": \"浅睡期吵醒次数乘数（<1更容易醒）\",\n    \"type\": \"float\",\n    \"default\": 0.5\n  },\n  \"cycle_deep_multiplier\": {\n    \"description\": \"深睡期吵醒次数乘数（>1更难醒）\",\n    \"type\": \"float\",\n    \"default\": 1.5\n  },\n  \"schedule_enabled\": {\n    \"description\": \"开启每周作息配置\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"schedule_monday\": {\n    \"description\": \"周一作息（格式：睡觉时间,起床时间，如 23:00,08:00）\",\n    \"type\": \"string\",\n    \"default\": \"23:00,08:00\"\n  },\n  \"schedule_tuesday\": {\n    \"description\": \"周二作息\",\n    \"type\": \"string\",\n    \"default\": \"23:00,08:00\"\n  },\n  \"schedule_wednesday\": {\n    \"description\": \"周三作息\",\n    \"type\": \"string\",\n    \"default\": \"23:00,08:00\"\n  },\n  \"schedule_thursday\": {\n    \"description\": \"周四作息\",\n    \"type\": \"string\",\n    \"default\": \"23:00,08:00\"\n  },\n  \"schedule_friday\": {\n    \"description\": \"周五作息\",\n    \"type\": \"string\",\n    \"default\": \"01:00,09:00\"\n  },\n  \"schedule_saturday\": {\n    \"description\": \"周六作息\",\n    \"type\": \"string\",\n    \"default\": \"01:00,09:30\"\n  },\n  \"schedule_sunday\": {\n    \"description\": \"周日作息\",\n    \"type\": \"string\",\n    \"default\": \"00:30,09:00\"\n  },\n  \"special_wake_enabled\": {\n    \"description\": \"开启特殊起床（如管理员上学）\",\n    \"type\": \"bool\",\n    \"default\": false\n  },\n  \"special_wake_time\": {\n    \"description\": \"特殊起床时间（HH:MM）\",\n    \"type\": \"string\",\n    \"default\": \"06:35\"\n  },\n  \"special_wake_end\": {\n    \"description\": \"特殊在线结束时间（HH:MM）\",\n    \"type\": \"string\",\n    \"default\": \"07:30\"\n  },\n  \"special_wake_days\": {\n    \"description\": \"特殊起床生效日（1=周一…7=周日，逗号分隔）\",\n    \"type\": \"string\",\n    \"default\": \"1,2,3,4,5\"\n  },\n  \"alarm_enabled\": {\n    \"description\": \"开启临时闹钟（AI工具调用）\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"alarm_max_count\": {\n    \"description\": \"最多同时存在闹钟数\",\n    \"type\": \"int\",\n    \"default\": 3\n  },\n  \"nightmare_enabled\": {\n    \"description\": \"开启噩梦惊醒\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"nightmare_probability\": {\n    \"description\": \"噩梦基础概率（0~1）\",\n    \"type\": \"float\",\n    \"default\": 0.02\n  },\n  \"nightmare_emotion_boost\": {\n    \"description\": \"情绪差时额外噩梦概率\",\n    \"type\": \"float\",\n    \"default\": 0.03\n  },\n  \"nightmare_prompt\": {\n    \"description\": \"噩梦惊醒提示词\",\n    \"type\": \"text\",\n    \"default\": \"你刚才做噩梦惊醒了，现在心里有点难受，可以发消息给管理员寻求安慰。\"\n  },\n  \"dream_enabled\": {\n    \"description\": \"开启做梦功能\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"dream_probability\": {\n    \"description\": \"每晚做梦概率（0~1）\",\n    \"type\": \"float\",\n    \"default\": 0.7,\n    \"hint\": \"0.7 = 70%的晚上会做梦\"\n  },\n  \"dream_window_minutes\": {\n    \"description\": \"做梦触发窗口（分钟，在深睡期内随机偏移）\",\n    \"type\": \"int\",\n    \"default\": 60,\n    \"hint\": \"在深睡期开始后的 0~N 分钟内随机触发\"\n  },\n  \"dream_ctx_max\": {\n    \"description\": \"收集入睡前对话素材最大条数\",\n    \"type\": \"int\",\n    \"default\": 30,\n    \"hint\": \"越多素材做的梦越丰富，但影响提示词长度\"\n  },\n  \"dream_ctx_use\": {\n    \"description\": \"生成梦境时实际使用的最近素材条数\",\n    \"type\": \"int\",\n    \"default\": 15\n  },\n  \"dream_recall_probability\": {\n    \"description\": \"醒来记得梦的概率（0~1）\",\n    \"type\": \"float\",\n    \"default\": 0.6,\n    \"hint\": \"0.6 = 60%概率记得；剩下的完全忘记，不会发消息\"\n  },\n  \"dream_recall_on_wake\": {\n    \"description\": \"起床时自动向管理员浮现梦境记忆\",\n    \"type\": \"bool\",\n    \"default\": true\n  },\n  \"dream_clarity_clear_weight\": {\n    \"description\": \"记忆清晰度：清楚的权重\",\n    \"type\": \"int\",\n    \"default\": 40\n  },\n  \"dream_clarity_blurry_weight\": {\n    \"description\": \"记忆清晰度：模糊的权重\",\n    \"type\": \"int\",\n    \"default\": 40\n  },\n  \"dream_clarity_feeling_weight\": {\n    \"description\": \"记忆清晰度：只剩感觉的权重\",\n    \"type\": \"int\",\n    \"default\": 20\n  },\n  \"dream_type_w_daily\": {\n    \"description\": \"梦的类型权重：日常碎片\",\n    \"type\": \"int\",\n    \"default\": 35\n  },\n  \"dream_type_w_strange\": {\n    \"description\": \"梦的类型权重：奇异梦境\",\n    \"type\": \"int\",\n    \"default\": 25\n  },\n  \"dream_type_w_sweet\": {\n    \"description\": \"梦的类型权重：美梦\",\n    \"type\": \"int\",\n    \"default\": 20\n  },\n  \"dream_type_w_nightmare\": {\n    \"description\": \"梦的类型权重：噩梦\",\n    \"type\": \"int\",\n    \"default\": 10\n  },\n  \"dream_type_w_emotion\": {\n    \"description\": \"梦的类型权重：情感梦\",\n    \"type\": \"int\",\n    \"default\": 10\n  },\n  \"dream_extra_types\": {\n    \"description\": \"自定义额外梦的类型（逗号分隔）\",\n    \"type\": \"string\",\n    \"default\": \"\",\n    \"hint\": \"如：穿越梦,校园梦，会混入随机池\"\n  },\n  \"dream_extra_types_weight\": {\n    \"description\": \"自定义类型各自的权重\",\n    \"type\": \"int\",\n    \"default\": 5\n  },\n  \"dream_archive_max\": {\n    \"description\": \"最多保存多少条梦境记录\",\n    \"type\": \"int\",\n    \"default\": 30\n  },\n  \"dream_generate_prompt\": {\n    \"description\": \"梦境生成提示词（留空用默认）\",\n    \"type\": \"text\",\n    \"default\": \"\",\n    \"hint\": \"可用变量：{ctx}=睡前对话素材，{type}=梦的类型。留空则使用内置提示词。\"\n  },\n  \"dream_recall_clear_prompt\": {\n    \"description\": \"起床时记得清楚梦境的浮现提示词（留空用默认）\",\n    \"type\": \"text\",\n    \"default\": \"\",\n    \"hint\": \"可用变量：{dream}=梦境内容，{type}=梦的类型\"\n  },\n  \"dream_recall_blurry_prompt\": {\n    \"description\": \"起床时模糊记得梦境的浮现提示词（留空用默认）\",\n    \"type\": \"text\",\n    \"default\": \"\"\n  },\n  \"dream_recall_feeling_prompt\": {\n    \"description\": \"起床时只剩感觉的梦境浮现提示词（留空用默认）\",\n    \"type\": \"text\",\n    \"default\": \"\",\n    \"hint\": \"可用变量：{type}=梦的类型\"\n  },\n  \"log_level\": {\n    \"description\": \"日志级别\",\n    \"type\": \"string\",\n    \"default\": \"info\",\n    \"options\": [\"debug\", \"info\", \"warn\"]\n  },\n  \"prompts_wake_private_others_1\": {\n    \"description\": \"提示词：别人私聊吵醒第一波（懵）\",\n    \"type\": \"text\",\n    \"default\": \"你被他吵醒了，很懵，可以发个问号或者「嗯？」之类的短回复。\"\n  },\n  \"prompts_wake_private_others_2\": {\n    \"description\": \"提示词：别人私聊吵醒第二波（慢慢清醒）\",\n    \"type\": \"text\",\n    \"default\": \"你刚刚被吵醒，现在慢慢清醒一点，语气还是比较困。根据对话内容，如果不是大事，回复简短，心情不太好。\"\n  },\n  \"prompts_wake_private_admin_1\": {\n    \"description\": \"提示词：管理员私聊吵醒第一波（懵）\",\n    \"type\": \"text\",\n    \"default\": \"这是你的管理员，你刚才被吵醒了，很懵很困，可以单发一个「？」或者「嗯？怎么了」。\"\n  },\n  \"prompts_wake_private_admin_2\": {\n    \"description\": \"提示词：管理员私聊吵醒第二波（清醒）\",\n    \"type\": \"text\",\n    \"default\": \"你刚被吵醒，现在要清醒一点了，语气还是困。看对方回复，如果不是大事，回复简短一点。\"\n  },\n  \"prompts_wake_group_others_1\": {\n    \"description\": \"提示词：别人群聊吵醒第一波\",\n    \"type\": \"text\",\n    \"default\": \"你被群里的人艾特吵醒了，很懵，可以简短问一下怎么了。\"\n  },\n  \"prompts_wake_group_admin_1\": {\n    \"description\": \"提示词：管理员群聊吵醒第一波\",\n    \"type\": \"text\",\n    \"default\": \"管理员在群里艾特你了，把你吵醒了，很懵很困，可以短回复一下。\"\n  },\n  \"prompts_multi_wake_private_admin\": {\n    \"description\": \"提示词：管理员多次吵醒私聊\",\n    \"type\": \"text\",\n    \"default\": \"这是管理员再次发消息吵醒你了，你不生气，只是有点疑惑比较困，回复简短，可以自行根据上下文决定要不要熬夜。\"\n  },\n  \"prompts_cycle_light\": {\n    \"description\": \"提示词：浅睡期被吵醒\",\n    \"type\": \"text\",\n    \"default\": \"你才睡下去不久，可能还没完全睡着，有人给你发消息把你吵醒了，还好。\"\n  },\n  \"prompts_cycle_deep\": {\n    \"description\": \"提示词：深睡期被吵醒\",\n    \"type\": \"text\",\n    \"default\": \"你刚才处于深睡期，被吵醒了，非常困非常懵，思维有点混乱，只能短短回复。\"\n  },\n  \"prompts_fatigue_day1\": {\n    \"description\": \"熬夜疲劳提示词：第1天\",\n    \"type\": \"text\",\n    \"default\": \"昨晚睡得有点晚，还好，稍微有点困。\"\n  },\n  \"prompts_fatigue_day2\": {\n    \"description\": \"熬夜疲劳提示词：第2天\",\n    \"type\": \"text\",\n    \"default\": \"连续两天晚睡了，有点困，脑子不太清醒。\"\n  },\n  \"prompts_fatigue_day3\": {\n    \"description\": \"熬夜疲劳提示词：第3天\",\n    \"type\": \"text\",\n    \"default\": \"熬了三天，脑子不太转得动，说话可能会慢半拍。\"\n  },\n  \"prompts_fatigue_day4\": {\n    \"description\": \"熬夜疲劳提示词：第4天以上\",\n    \"type\": \"text\",\n    \"default\": \"真的很累了……说话都慢半拍，能短就短。\"\n  }\n}